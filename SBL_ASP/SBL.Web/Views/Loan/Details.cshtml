@model SBL.Web.Models.ViewModels.ApplicationDetailViewModel
@{
    var workflowStages = new[] {
        new { Status = "draft", Label = "Draft" },
        new { Status = "submitted", Label = "Submitted" },
        new { Status = "cib_pending", Label = "CIB Pending" },
        new { Status = "cib_completed", Label = "CIB Completed" },
        new { Status = "under_review", Label = "Under Review" },
        new { Status = "approved", Label = "Approved" },
        new { Status = "sanction_generated", Label = "Sanction Generated" },
        new { Status = "charge_docs_pending", Label = "Charge Docs Pending" },
        new { Status = "charge_docs_submitted", Label = "Charge Docs Submitted" },
        new { Status = "limit_loaded", Label = "Limit Loaded" },
        new { Status = "disbursed", Label = "Disbursed" }
    };

    var statusOrder = workflowStages.Select(s => s.Status).ToList();
    var currentIdx = statusOrder.IndexOf(Model.Status);
    var tat = (DateTime.Now - Model.CreatedAt).Days;
    var uploadedCount = Model.Documents.Count(d => d.Uploaded);
}

<div class="space-y-6 animate-fade-in">
    <!-- Breadcrumb / Header -->
    <div class="flex items-center gap-3">
        <a asp-action="Index" class="h-9 w-9 flex items-center justify-center rounded-xl border border-slate-200 bg-white hover:bg-slate-50 transition-all text-slate-600">
            <i data-lucide="arrow-left" class="h-4 w-4"></i>
        </a>
        <div class="flex-1">
            <div class="flex items-center gap-3">
                <h1 class="text-xl font-bold tracking-tight text-slate-900">@Model.Id</h1>
                <span class="px-2.5 py-0.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-primary/10 text-primary border border-primary/20">
                    @Model.Status.Replace("_", " ")
                </span>
            </div>
            <p class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider">
                @Model.CustomerName • @Model.LoanType • @Model.Amount
            </p>
        </div>
        <div class="flex gap-2">
            <button class="px-4 py-2 bg-white border border-slate-200 text-[10px] font-bold uppercase tracking-widest rounded-xl hover:bg-slate-50 transition-all flex items-center gap-2">
                <i data-lucide="edit-3" class="h-3.5 w-3.5"></i> Edit
            </button>
            <button class="px-4 py-2 bg-primary text-white text-[10px] font-bold uppercase tracking-widest rounded-xl shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex items-center gap-2">
                <i data-lucide="check-circle" class="h-3.5 w-3.5"></i> Approve
            </button>
        </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Loan Information -->
            <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
                <div class="p-4 border-b bg-slate-50/50">
                    <h3 class="text-[10px] font-black uppercase tracking-widest text-slate-500 flex items-center gap-2">
                        <i data-lucide="file-text" class="w-4 h-4"></i> Loan Information
                    </h3>
                </div>
                <div class="p-6">
                    <div class="grid gap-6 sm:grid-cols-2 text-sm">
                        <div class="space-y-1">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Customer</p>
                            <p class="font-normal text-slate-900">@Model.CustomerName</p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Loan Type</p>
                            <p class="font-normal text-slate-900">@Model.LoanType</p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Amount</p>
                            <p class="font-normal text-emerald-600">@Model.Amount</p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Tenure</p>
                            <p class="font-normal text-slate-900">@Model.Tenure</p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Branch</p>
                            <p class="font-normal text-slate-900">@Model.Branch</p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Relationship Manager</p>
                            <p class="font-normal text-slate-900">@Model.RmName</p>
                        </div>
                        <div class="sm:col-span-2 space-y-1">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Purpose of Loan</p>
                            <p class="font-normal text-slate-700 leading-relaxed">@Model.Purpose</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Document Checklist -->
            <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
                <div class="p-4 border-b bg-slate-50/50 flex items-center justify-between">
                    <h3 class="text-[10px] font-black uppercase tracking-widest text-slate-500 flex items-center gap-2">
                        <i data-lucide="check-square" class="w-4 h-4"></i> Document Checklist
                    </h3>
                    <span class="text-[10px] font-bold bg-slate-100 text-slate-600 px-2 py-1 rounded-lg">@uploadedCount/@Model.Documents.Count UPLOADED</span>
                </div>
                <div class="p-4 space-y-2">
                    @foreach (var doc in Model.Documents)
                    {
                        <div class="flex items-center gap-3 p-3 rounded-xl border @(doc.Uploaded ? "border-emerald-100 bg-emerald-50/30" : "border-red-100 bg-red-50/30") transition-all">
                            <div class="h-8 w-8 rounded-full flex items-center justify-center @(doc.Uploaded ? "bg-emerald-100 text-emerald-600" : "bg-red-100 text-red-600")">
                                <i data-lucide="@(doc.Uploaded ? "check" : "x")" class="h-4 w-4"></i>
                            </div>
                            <span class="text-xs font-bold @(doc.Uploaded ? "text-slate-700" : "text-red-700")">@doc.Name</span>
                            @if (!doc.Uploaded) {
                                <button class="ml-auto text-[9px] font-black uppercase tracking-widest text-primary hover:underline">Upload Now</button>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar / Timeline -->
        <div class="space-y-6">
            <!-- TAT Card -->
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="flex items-center gap-4">
                    <div class="h-14 w-14 rounded-2xl flex items-center justify-center @(tat > 7 ? "bg-red-50 text-red-600" : tat > 3 ? "bg-amber-50 text-amber-600" : "bg-emerald-50 text-emerald-600")">
                        <i data-lucide="clock" class="h-7 w-7"></i>
                    </div>
                    <div>
                        <div class="text-2xl font-black text-slate-900">@tat Days</div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Current Turn Around Time</p>
                    </div>
                </div>
                <div class="mt-4 pt-4 border-t border-slate-50 flex items-center justify-between text-[10px] font-bold uppercase tracking-widest">
                    <span class="text-slate-400">Created Date:</span>
                    <span class="text-slate-700">@Model.CreatedAt.ToString("dd MMM yyyy")</span>
                </div>
            </div>

            <!-- Workflow Timeline -->
            <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
                <div class="p-4 border-b bg-slate-50/50">
                    <h3 class="text-[10px] font-black uppercase tracking-widest text-slate-500 flex items-center gap-2">
                        <i data-lucide="git-merge" class="w-4 h-4"></i> Application Workflow
                    </h3>
                </div>
                <div class="p-6">
                    <!-- ... timeline content ... -->
                </div>
            </div>

            <!-- Communication Hub (Moved from Profile) -->
            <div class="rounded-2xl border border-slate-200 bg-white shadow-xl overflow-hidden group">
                <div class="p-6 bg-slate-900 text-white relative overflow-hidden">
                    <i data-lucide="messages-square" class="absolute -right-2 -bottom-2 w-20 h-20 opacity-10 group-hover:scale-110 transition-transform duration-500"></i>
                    <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-emerald-400">Direct Support</h3>
                    <p class="text-xl font-bold mt-2 tracking-tight">Communication Hub</p>
                    <p class="text-[10px] mt-2 opacity-70 font-medium leading-relaxed">Securely chat with CAD Admins regarding this application.</p>
                </div>
                <div class="p-4 bg-white">
                    <a asp-controller="Account" asp-action="Conversation" asp-route-appId="@Model.Id" class="w-full py-3 bg-primary text-white rounded-xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex items-center justify-center gap-2">
                        <i data-lucide="message-circle" class="w-4 h-4"></i> Open Chat
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
        });
    </script>
}
