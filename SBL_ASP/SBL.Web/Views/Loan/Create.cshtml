@model SBL.Web.Models.ViewModels.LoanApplicationViewModel
@using SBL.Web.Models.ViewModels

@{
    ViewData["Title"] = "New Loan Application";
}

<div class="max-w-7xl mx-auto space-y-8 animate-fade-in pb-20">
    <!-- Wizard Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b pb-6">
        <div>
            <h1 class="text-2xl text-slate-950 tracking-tight">New Loan Application</h1>
            <p class="text-sm text-slate-500 uppercase tracking-widest">SBL/SBL PLUS Workflow</p>
        </div>
        <div class="flex items-center gap-2">
            <div class="px-3 py-1.5 bg-slate-100 rounded-lg text-[10px] uppercase tracking-widest text-slate-600 border border-slate-200">
                Draft Mode
            </div>
        </div>
    </div>

    <!-- Step Progress Tracker -->
    <div class="grid grid-cols-4 gap-4">
        <div id="tab-1" class="step-tab group cursor-pointer" onclick="goToStep(1)">
            <div class="h-1.5 w-full bg-primary rounded-full transition-all" id="bar-1"></div>
            <p class="mt-3 text-[10px] uppercase tracking-widest text-primary" id="text-1">1. Personal Info</p>
        </div>
        <div id="tab-2" class="step-tab group cursor-pointer" onclick="goToStep(2)">
            <div class="h-1.5 w-full bg-slate-200 rounded-full transition-all" id="bar-2"></div>
            <p class="mt-3 text-[10px] uppercase tracking-widest text-slate-400" id="text-2">2. Loan Details</p>
        </div>
        <div id="tab-3" class="step-tab group cursor-pointer" onclick="goToStep(3)">
            <div class="h-1.5 w-full bg-slate-200 rounded-full transition-all" id="bar-3"></div>
            <p class="mt-3 text-[10px] uppercase tracking-widest text-slate-400" id="text-3">3. Documents</p>
        </div>
        <div id="tab-4" class="step-tab group cursor-pointer" onclick="goToStep(4)">
            <div class="h-1.5 w-full bg-slate-200 rounded-full transition-all" id="bar-4"></div>
            <p class="mt-3 text-[10px] uppercase tracking-widest text-slate-400" id="text-4">4. Review & Submit</p>
        </div>
    </div>

    <form asp-action="Create" method="post" id="loanWizardForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CurrentStep" id="hdnStep" />

        <!-- STEP 1: PERSONAL & PROFESSIONAL -->
        <div id="step-content-1" class="step-content space-y-6">
            <div class="bg-white rounded-xl border border-slate-300 shadow-sm overflow-hidden">
                <div class="p-6 border-b bg-slate-50 flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div>
                        <h3 class="text-sm text-slate-950 uppercase tracking-tight">Customer Identification</h3>
                        <p class="text-xs text-slate-500">Enter account number to fetch system data.</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <input type="text" asp-for="AccountNumber" id="accNo" placeholder="Account No (e.g. 0012...)" 
                               class="h-10 px-4 bg-white border border-slate-300 rounded-lg text-xs focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 outline-none transition-all w-64 font-normal" />
                        <button type="button" onclick="lookupAccount()" class="h-10 px-6 bg-blue-600 text-white text-[10px] uppercase tracking-widest rounded-lg hover:bg-blue-700 transition-all flex items-center gap-2">
                            <i data-lucide="search" class="w-4 h-4"></i> Fetch
                        </button>
                    </div>
                </div>
                <div class="p-8 grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
                    <div class="space-y-1.5">
                        <label class="text-[10px] uppercase tracking-widest text-slate-500">Full Name</label>
                        <input asp-for="CustomerName" class="w-full h-10 px-4 bg-slate-50 border border-slate-200 rounded-lg text-xs font-semibold outline-none focus:border-primary focus:bg-white transition-all" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] uppercase tracking-widest text-slate-500">Father's Name</label>
                        <input asp-for="FathersName" class="w-full h-10 px-4 bg-slate-50 border border-slate-200 rounded-lg text-xs font-semibold outline-none focus:border-primary focus:bg-white transition-all" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] uppercase tracking-widest text-slate-500">Mother's Name</label>
                        <input asp-for="MothersName" class="w-full h-10 px-4 bg-slate-50 border border-slate-200 rounded-lg text-xs font-semibold outline-none focus:border-primary focus:bg-white transition-all" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] uppercase tracking-widest text-slate-500">Date of Birth</label>
                        <input type="text" asp-for="DateOfBirth" class="w-full h-10 px-4 bg-slate-50 border border-slate-200 rounded-lg text-xs font-semibold outline-none focus:border-primary focus:bg-white transition-all fp-date" />
                    </div>
                    
                    <div class="space-y-1.5">
                        <label class="text-[10px] uppercase tracking-widest text-slate-500">National ID</label>
                        <input asp-for="NID" class="w-full h-10 px-4 bg-slate-50 border border-slate-200 rounded-lg text-xs font-semibold outline-none focus:border-primary focus:bg-white transition-all" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] uppercase tracking-widest text-slate-500">TIN Number</label>
                        <input asp-for="TIN" class="w-full h-10 px-4 bg-slate-50 border border-slate-200 rounded-lg text-xs font-semibold outline-none focus:border-primary focus:bg-white transition-all" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] uppercase tracking-widest text-slate-500">Mobile Number</label>
                        <input asp-for="MobileNumber" class="w-full h-10 px-4 bg-slate-50 border border-slate-200 rounded-lg text-xs font-semibold outline-none focus:border-primary focus:bg-white transition-all" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] uppercase tracking-widest text-slate-500">Email Address</label>
                        <input type="email" asp-for="Email" class="w-full h-10 px-4 bg-slate-50 border border-slate-200 rounded-lg text-xs font-semibold outline-none focus:border-primary focus:bg-white transition-all" />
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-[10px] uppercase tracking-widest text-slate-500">Organization</label>
                        <input asp-for="OrganizationName" class="w-full h-10 px-4 bg-slate-50 border border-slate-200 rounded-lg text-xs font-semibold outline-none focus:border-primary focus:bg-white transition-all" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] uppercase tracking-widest text-slate-500">Designation</label>
                        <input asp-for="Designation" class="w-full h-10 px-4 bg-slate-50 border border-slate-200 rounded-lg text-xs font-semibold outline-none focus:border-primary focus:bg-white transition-all" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] uppercase tracking-widest text-slate-500">Monthly Income</label>
                        <input type="number" asp-for="MonthlyIncome" class="w-full h-10 px-4 bg-slate-50 border border-slate-200 rounded-lg text-xs font-semibold outline-none focus:border-primary focus:bg-white transition-all" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] uppercase tracking-widest text-slate-500">Gender</label>
                        <select asp-for="Gender" class="w-full">
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>

                    <div class="md:col-span-4 space-y-1.5 pt-4 border-t border-slate-100">
                        <label class="text-[10px] uppercase tracking-widest text-slate-500">Present Address</label>
                        <textarea asp-for="PresentAddress" rows="2" class="w-full p-4 bg-white border border-slate-300 rounded-lg text-xs font-normal outline-none focus:border-primary transition-all"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- STEP 2: LOAN INFORMATION -->
        <div id="step-content-2" class="step-content hidden space-y-6">
            <div class="bg-white rounded-xl border border-slate-300 shadow-sm p-8 space-y-8">
                <div class="space-y-4">
                    <h3 class="text-sm text-slate-950 uppercase tracking-tight flex items-center gap-2 border-b pb-4">
                        <i data-lucide="banknote" class="w-5 h-5 text-primary"></i> Proposed Facility Details
                    </h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                        <div class="space-y-1.5">
                            <label class="text-[10px] uppercase tracking-widest text-slate-500">Requested Amount (BDT)</label>
                            <input type="number" asp-for="RequestedAmount" class="w-full h-10 px-4 bg-slate-50 border border-slate-200 rounded-lg text-sm font-bold text-primary outline-none focus:border-primary focus:bg-white transition-all" />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-[10px] uppercase tracking-widest text-slate-500">Tenure (Months)</label>
                            <input type="number" asp-for="RequestedTenure" class="w-full h-10 px-4 bg-slate-50 border border-slate-200 rounded-lg text-xs font-semibold outline-none focus:border-primary focus:bg-white transition-all" />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-[10px] uppercase tracking-widest text-slate-500">Repayment Mode</label>
                            <select asp-for="RepaymentMode" class="w-full">
                                <option value="EMI">Monthly EMI</option>
                                <option value="QUARTERLY">Quarterly Installment</option>
                                <option value="BULLET">Bullet Repayment</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="space-y-4 pt-6 border-t">
                    <h3 class="text-sm text-slate-950 uppercase tracking-tight flex items-center gap-2">
                        <i data-lucide="info" class="w-5 h-5 text-primary"></i> Utilization & Purpose
                    </h3>
                    <div class="space-y-1.5">
                        <label class="text-[10px] uppercase tracking-widest text-slate-500">Detailed Purpose</label>
                        <textarea asp-for="Purpose" rows="3" class="w-full p-4 bg-slate-50 border border-slate-200 rounded-lg text-xs font-semibold outline-none focus:border-primary focus:bg-white transition-all" placeholder="Explain why the loan is needed..."></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- STEP 3: DOCUMENTS -->
        <div id="step-content-3" class="step-content hidden space-y-6">
            <div class="bg-white rounded-xl border border-slate-300 shadow-sm p-8">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-sm text-slate-950 uppercase tracking-tight">Required Document Checklist</h3>
                    <span class="text-[10px] text-slate-400 uppercase tracking-widest">SBL Standard Set</span>
                </div>
                <div class="grid gap-3 md:grid-cols-2">
                    @for (int i = 0; i < Model.Documents.Count; i++)
                    {
                        <div class="flex items-center gap-4 p-4 border border-slate-200 rounded-lg bg-white group hover:border-primary/20 transition-all">
                            <div class="h-10 w-10 flex items-center justify-center rounded-lg bg-slate-50 border border-slate-200 text-slate-400">
                                <i data-lucide="file" class="w-5 h-5"></i>
                            </div>
                            <div class="flex-1">
                                <p class="text-xs text-slate-700">@Model.Documents[i].Name</p>
                                <p class="text-[9px] text-slate-400 uppercase">PDF, JPEG or PNG (Max 5MB)</p>
                            </div>
                            <button type="button" class="px-4 py-2 bg-white border border-slate-300 text-[10px] uppercase tracking-widest rounded-lg hover:bg-slate-50 transition-all">
                                Upload
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- STEP 4: REVIEW -->
        <div id="step-content-4" class="step-content hidden space-y-6">
            <div class="bg-white rounded-xl border border-slate-300 shadow-sm p-8 space-y-8">
                <div class="flex items-center gap-4 text-emerald-600 bg-emerald-50 p-4 rounded-lg border border-emerald-100">
                    <i data-lucide="shield-check" class="w-6 h-6"></i>
                    <p class="text-xs leading-relaxed">Please review the data carefully. Once submitted, the application will be locked for verification by the CAD and Audit teams.</p>
                </div>

                <div class="grid md:grid-cols-2 gap-8">
                    <div class="space-y-4">
                        <h4 class="text-[10px] uppercase tracking-[0.2em] text-slate-500">Review Information</h4>
                        <div class="space-y-3">
                            <div class="flex justify-between border-b border-slate-100 pb-2">
                                <span class="text-xs text-slate-500">Customer</span>
                                <span class="text-xs text-slate-950" id="rev-name">-</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-100 pb-2">
                                <span class="text-xs text-slate-500">Account No</span>
                                <span class="text-xs text-slate-950" id="rev-acc">-</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-100 pb-2">
                                <span class="text-xs text-slate-500">Proposed Amount</span>
                                <span class="text-xs text-primary" id="rev-amt">-</span>
                            </div>
                        </div>
                    </div>
                    <div class="space-y-4">
                        <h4 class="text-[10px] uppercase tracking-[0.2em] text-slate-500">Actions</h4>
                        <div class="flex flex-col gap-3">
                            <button type="submit" asp-action="DownloadProposal" class="w-full h-10 border border-slate-300 rounded-lg text-[10px] uppercase tracking-widest text-slate-600 hover:bg-slate-50 transition-all flex items-center justify-center gap-2">
                                <i data-lucide="file-text" class="w-4 h-4"></i> Download Proposal
                            </button>
                            <button type="submit" asp-action="DownloadSanction" class="w-full h-10 border border-slate-300 rounded-lg text-[10px] uppercase tracking-widest text-slate-600 hover:bg-slate-50 transition-all flex items-center justify-center gap-2">
                                <i data-lucide="file-check" class="w-4 h-4"></i> Preview Sanction
                            </button>
                        </div>
                    </div>
                </div>

                <div class="pt-6 border-t flex items-center gap-3">
                    <input type="checkbox" asp-for="IsAgreedToTerms" class="h-5 w-5 rounded border-slate-300 text-primary focus:ring-primary" />
                    <label class="text-xs text-slate-600 cursor-pointer">I confirm that all provided information is accurate and verified against original documents.</label>
                </div>
            </div>
        </div>

        <!-- Wizard Navigation -->
        <div class="mt-10 flex items-center justify-between">
            <button type="button" id="btnPrev" onclick="moveStep(-1)" class="h-10 px-8 rounded-lg border border-slate-300 text-[10px] uppercase tracking-widest text-slate-500 hover:bg-slate-50 transition-all hidden">
                Previous Step
            </button>
            <div class="ml-auto flex items-center gap-4">
                <a asp-action="Index" class="text-[10px] uppercase tracking-widest text-slate-400 hover:text-red-500 transition-all">Discard Draft</a>
                <button type="button" id="btnNext" onclick="moveStep(1)" class="h-10 px-10 bg-primary text-white text-[10px] uppercase tracking-widest rounded-lg shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all">
                    Next Step <i data-lucide="arrow-right" class="w-4 h-4 ml-2"></i>
                </button>
                <button type="submit" id="btnSubmit" class="h-10 px-10 bg-emerald-600 text-white text-[10px] uppercase tracking-widest rounded-lg shadow-lg shadow-emerald-600/20 hover:bg-emerald-700 transition-all hidden">
                    Submit Application <i data-lucide="check-circle" class="w-4 h-4 ml-2"></i>
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        let currentStep = 1;
        const totalSteps = 4;

        function goToStep(step) {
            if(step > currentStep && !validateCurrentStep()) return;
            currentStep = step;
            updateUI();
        }

        function moveStep(delta) {
            if(delta > 0 && !validateCurrentStep()) return;
            currentStep += delta;
            updateUI();
        }

        function validateCurrentStep() {
            if (currentStep === 1) {
                if (!document.getElementById('CustomerName').value) {
                    MTBToast.error("Please lookup an account to continue.");
                    return false;
                }
            }
            return true;
        }

        function updateUI() {
            // Update tabs
            for(let i=1; i<=totalSteps; i++) {
                const bar = document.getElementById(`bar-${i}`);
                const text = document.getElementById(`text-${i}`);
                const content = document.getElementById(`step-content-${i}`);

                if(i <= currentStep) {
                    bar.classList.replace('bg-slate-200', 'bg-primary');
                    text.classList.replace('text-slate-400', 'text-primary');
                } else {
                    bar.classList.replace('bg-primary', 'bg-slate-200');
                    text.classList.replace('text-primary', 'text-slate-400');
                }

                content.classList.toggle('hidden', i !== currentStep);
            }

            // Update buttons
            document.getElementById('btnPrev').classList.toggle('hidden', currentStep === 1);
            document.getElementById('btnNext').classList.toggle('hidden', currentStep === totalSteps);
            document.getElementById('btnSubmit').classList.toggle('hidden', currentStep !== totalSteps);

            // Sync review data
            if(currentStep === 4) {
                document.getElementById('rev-name').innerText = document.getElementById('CustomerName').value;
                document.getElementById('rev-acc').innerText = document.getElementById('accNo').value;
                document.getElementById('rev-amt').innerText = "BDT " + Number(document.getElementById('RequestedAmount').value).toLocaleString();
            }

            window.scrollTo({ top: 0, behavior: 'smooth' });
            lucide.createIcons();
        }

        async function lookupAccount() {
            const accNo = document.getElementById('accNo').value;
            if(!accNo) { MTBToast.error("Enter account number"); return; }

            MTBLoader.show();
            try {
                const response = await fetch(`@Url.Action("LookupAccount", "Loan")?accountNumber=${accNo}`);
                const result = await response.json();
                
                if(result.success) {
                    const data = result.data;
                    document.getElementById('CustomerName').value = data.customerName;
                    document.getElementById('FathersName').value = data.fathersName;
                    document.getElementById('MothersName').value = data.mothersName;
                    document.getElementById('DateOfBirth').value = data.dob;
                    document.getElementById('NID').value = data.nid;
                    document.getElementById('MobileNumber').value = data.mobile;
                    document.getElementById('PresentAddress').value = data.presentAddress;
                    
                    // Added mappings for missing fields
                    if(document.getElementById('TIN')) document.getElementById('TIN').value = data.tin;
                    if(document.getElementById('OrganizationName')) document.getElementById('OrganizationName').value = data.orgName;
                    if(document.getElementById('Designation')) document.getElementById('Designation').value = data.designation;
                    if(document.getElementById('MonthlyIncome')) document.getElementById('MonthlyIncome').value = data.income;

                    MTBToast.success("Data fetched successfully.");
                } else {
                    MTBToast.error("Account not found.");
                }
            } catch (e) {
                MTBToast.error("API Connection Error");
            } finally {
                MTBLoader.hide();
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            flatpickr(".fp-date", window.MTBFlatpickrConfig);
            
            // Initialize TomSelect for all select elements
            document.querySelectorAll('select').forEach(el => {
                new TomSelect(el, {
                    create: false,
                    controlInput: null,
                    render: {
                        option: function(data, escape) {
                            return `<div class="py-2 px-3 text-xs uppercase tracking-widest font-semibold">${escape(data.text)}</div>`;
                        },
                        item: function(data, escape) {
                            return `<div class="text-xs uppercase tracking-widest font-semibold">${escape(data.text)}</div>`;
                        }
                    }
                });
            });

            updateUI();
        });
    </script>
}
