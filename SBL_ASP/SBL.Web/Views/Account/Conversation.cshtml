@model SBL.Web.Models.ViewModels.ConversationViewModel

<div class="max-w-4xl mx-auto h-[calc(100vh-12rem)] flex flex-col bg-white rounded-3xl border border-slate-200 shadow-xl overflow-hidden animate-fade-in">
    <!-- Chat Header -->
    <div class="p-4 border-b bg-slate-50/50 flex items-center gap-4">
        @{
            var backUrl = string.IsNullOrEmpty(ViewData["AppId"]?.ToString()) 
                ? Url.Action("Profile") 
                : Url.Action("Details", "Loan", new { id = ViewData["AppId"] });
        }
        <a href="@backUrl" class="h-10 w-10 flex items-center justify-center rounded-xl bg-white border border-slate-200 hover:bg-slate-50 transition-all text-slate-600">
            <i data-lucide="arrow-left" class="h-5 w-5"></i>
        </a>
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary text-white font-black shadow-lg shadow-primary/20">
            @Model.OtherUserName[0]
        </div>
        <div>
            <h2 class="text-sm font-black text-slate-900 leading-tight">@Model.OtherUserName</h2>
            <p class="text-[10px] font-bold text-emerald-600 uppercase tracking-widest flex items-center gap-1.5">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                @Model.OtherUserDept • Online
            </p>
        </div>
        <div class="ml-auto flex gap-2">
            <button class="h-10 w-10 flex items-center justify-center rounded-xl hover:bg-slate-100 transition-all text-slate-400">
                <i data-lucide="search" class="h-5 w-5"></i>
            </button>
            <button class="h-10 w-10 flex items-center justify-center rounded-xl hover:bg-slate-100 transition-all text-slate-400">
                <i data-lucide="more-vertical" class="h-5 w-5"></i>
            </button>
        </div>
    </div>

    <!-- Messages Area -->
    <div id="chatContainer" class="flex-1 overflow-y-auto p-6 space-y-6 bg-slate-50/30">
        @foreach (var msg in Model.Messages)
        {
            <div class="flex @(msg.IsMe ? "justify-end" : "justify-start")">
                <div class="max-w-[80%] md:max-w-[70%] space-y-1">
                    <!-- Sender Info -->
                    <div class="flex items-center gap-2 px-1 @(msg.IsMe ? "flex-row-reverse" : "flex-row")">
                        <span class="text-[9px] font-normal uppercase tracking-widest text-slate-400">@msg.SenderName</span>
                        <span class="text-[8px] font-normal px-1.5 py-0.5 rounded bg-slate-100 text-slate-500 uppercase">@msg.SenderDept</span>
                    </div>

                    <!-- Message Bubble -->
                    <div class="relative p-4 rounded-2xl shadow-sm text-xs leading-relaxed
                        @(msg.IsMe 
                            ? "bg-blue-50 text-slate-900 rounded-tr-none font-normal border border-blue-100" 
                            : "bg-white border border-slate-100 text-slate-700 rounded-tl-none font-normal")">
                        @msg.Message
                        
                        <!-- Timestamp -->
                        <div class="mt-2 flex items-center justify-end gap-1 opacity-60 text-[8px] font-normal uppercase">
                            @msg.Timestamp.ToString("hh:mm tt")
                            @if(msg.IsMe) {
                                <i data-lucide="check-double" class="h-3 w-3"></i>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Message Input -->
    <div class="p-4 border-t bg-white">
        <form id="chatForm" class="flex items-center gap-3">
            <div class="flex-1 relative">
                <input type="text" id="messageInput" placeholder="Type your message here..." 
                       class="w-full h-12 pl-4 pr-12 bg-slate-50 border border-slate-100 rounded-2xl text-xs font-normal focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 outline-none transition-all" />
                <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-300 hover:text-amber-500 transition-all">
                    <i data-lucide="smile" class="h-5 w-5"></i>
                </button>
            </div>
            <button type="submit" class="h-12 px-6 flex items-center justify-center rounded-2xl bg-blue-600 text-white shadow-lg shadow-blue-600/20 hover:bg-blue-700 active:scale-95 transition-all font-normal uppercase text-[10px] tracking-widest">
                <i data-lucide="send" class="h-4 w-4 mr-2"></i> Send
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
            
            const container = document.getElementById('chatContainer');
            container.scrollTop = container.scrollHeight;

            const form = document.getElementById('chatForm');
            const input = document.getElementById('messageInput');

            form.addEventListener('submit', (e) => {
                e.preventDefault();
                if(!input.value.trim()) return;

                const msg = input.value;
                input.value = '';

                // Add message to UI (Demo)
                const now = new Date();
                const time = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                
                const html = `
                    <div class="flex justify-end animate-fade-in">
                        <div class="max-w-[80%] md:max-w-[70%] space-y-1">
                            <div class="flex items-center gap-2 px-1 flex-row-reverse">
                                <span class="text-[9px] font-normal uppercase tracking-widest text-slate-400">Me</span>
                                <span class="text-[8px] font-normal px-1.5 py-0.5 rounded bg-slate-100 text-slate-500 uppercase">Branch</span>
                            </div>
                            <div class="relative p-4 rounded-2xl shadow-sm text-xs leading-relaxed bg-blue-50 text-slate-900 rounded-tr-none font-normal border border-blue-100">
                                ${msg}
                                <div class="mt-2 flex items-center justify-end gap-1 opacity-60 text-[8px] font-normal uppercase">
                                    ${time}
                                    <i data-lucide="check-double" class="h-3 w-3"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
                
                container.insertAdjacentHTML('beforeend', html);
                container.scrollTop = container.scrollHeight;
                lucide.createIcons();

                MTBToast.success("Message sent.");
            });
        });
    </script>
}
