@using Microsoft.AspNetCore.Http
@{
    var userName = Context.Session.GetString("UserName");
    var empId = Context.Session.GetString("EmpId");
    var role = Context.Session.GetString("UserRole");
    var branch = Context.Session.GetString("BranchName");
}

<div class="animate-fade-in space-y-6 pb-10">
    <!-- Header -->
    <div class="flex items-center gap-4 border-b pb-6">
        <div class="h-20 w-20 rounded-2xl bg-primary/10 flex items-center justify-center border-2 border-primary/20 shadow-inner">
            <span class="text-3xl font-bold text-primary">@userName?[0]</span>
        </div>
        <div>
            <h1 class="text-2xl font-bold text-slate-900 tracking-tight">@userName</h1>
            <p class="text-sm font-semibold text-primary uppercase tracking-widest">@role</p>
            <div class="flex items-center gap-2 mt-1">
                <span class="inline-flex items-center rounded-full bg-emerald-100 px-2 py-0.5 text-[10px] font-semibold text-emerald-700 uppercase tracking-tighter ring-1 ring-emerald-200">
                    Active Session
                </span>
                <span class="text-[10px] font-semibold text-slate-800 uppercase tracking-widest flex items-center gap-1">
                    <i data-lucide="clock" class="w-3 h-3"></i> Last Login: Today, 10:45 AM
                </span>
            </div>
        </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
        <!-- Details Card -->
        <div class="lg:col-span-2 space-y-6">
            <div class="rounded-2xl border bg-card text-card-foreground shadow-sm overflow-hidden">
                <div class="p-5 border-b bg-muted/10 flex items-center justify-between">
                    <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-500">Employee Information</h3>
                    <button class="text-[10px] font-semibold uppercase tracking-widest text-primary hover:underline">Edit Details</button>
                </div>
                <div class="p-6">
                    <div class="grid gap-y-6 gap-x-8 sm:grid-cols-2 text-sm">
                        <div class="space-y-1">
                            <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-800">Employee ID</p>
                            <p class="font-bold text-slate-900">@empId</p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-800">Full Name</p>
                            <p class="font-bold text-slate-900">@userName</p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-800">Primary Branch</p>
                            <p class="font-bold text-slate-900">@branch</p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-800">Department</p>
                            <p class="font-bold text-slate-900">SME Banking Division</p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-800">Official Email</p>
                            <p class="font-bold text-slate-900"></p>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-800">Contact Number</p>
                            <p class="font-bold text-slate-900">+880 1711-000000</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Security Card -->
            <div class="rounded-2xl border bg-card text-card-foreground shadow-sm overflow-hidden">
                <div class="p-5 border-b bg-muted/10">
                    <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-500">Security & Credentials</h3>
                </div>
                <div class="p-6 space-y-4">
                    <div class="flex items-center justify-between p-4 rounded-xl border border-slate-100 bg-slate-50/50">
                        <div class="flex items-center gap-3">
                            <div class="h-10 w-10 rounded-full bg-amber-100 flex items-center justify-center text-amber-600">
                                <i data-lucide="key-round" class="w-5 h-5"></i>
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-slate-900">Password Policy</p>
                                <p class="text-[10px] text-slate-500 font-medium">Last changed 45 days ago</p>
                            </div>
                        </div>
                        <button class="bg-white border border-slate-200 px-4 py-2 rounded-lg text-[10px] font-semibold uppercase tracking-widest hover:bg-slate-50 transition-all">Update</button>
                    </div>

                    <div class="flex items-center justify-between p-4 rounded-xl border border-slate-100 bg-slate-50/50">
                        <div class="flex items-center gap-3">
                            <div class="h-10 w-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">
                                <i data-lucide="shield-check" class="w-5 h-5"></i>
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-slate-900">Two-Factor Authentication</p>
                                <p class="text-[10px] text-slate-500 font-semibold text-emerald-600 uppercase">Enabled via SMS</p>
                            </div>
                        </div>
                        <button class="bg-white border border-slate-200 px-4 py-2 rounded-lg text-[10px] font-semibold uppercase tracking-widest hover:bg-slate-50 transition-all">Manage</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Column -->
        <div class="space-y-6">
            <!-- Access Level -->
            <div class="rounded-2xl border bg-primary text-primary-foreground shadow-xl p-6 relative overflow-hidden group">
                <i data-lucide="award" class="absolute -right-4 -bottom-4 w-24 h-24 opacity-10 group-hover:scale-110 transition-transform duration-500"></i>
                <h3 class="text-xs font-semibold uppercase tracking-[0.2em] opacity-80">Access Level</h3>
                <p class="text-2xl font-bold mt-2 tracking-tighter">Gold Tier RM</p>
                <div class="mt-6 pt-6 border-t border-white/10 flex items-center justify-between">
                    <span class="text-[10px] font-semibold uppercase opacity-70">Approval Limit</span>
                    <span class="text-sm font-bold">৳5,000,000</span>
                </div>
            </div>

            <!-- Activity Logs -->
            <div class="rounded-2xl border bg-card text-card-foreground shadow-sm overflow-hidden">
                <div class="p-5 border-b bg-muted/10 flex items-center justify-between">
                    <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-500">Recent Activity</h3>
                    <i data-lucide="history" class="w-4 h-4 text-slate-800"></i>
                </div>
                <div class="p-0">
                    <ul class="divide-y divide-slate-50">
                        <li class="p-4 hover:bg-slate-50 transition-colors">
                            <p class="text-[11px] font-semibold text-slate-900">Submitted Loan #88421</p>
                            <p class="text-[9px] text-slate-800 uppercase font-medium mt-0.5">2 hours ago</p>
                        </li>
                        <li class="p-4 hover:bg-slate-50 transition-colors">
                            <p class="text-[11px] font-semibold text-slate-900">Approved CIB for XYZ Traders</p>
                            <p class="text-[9px] text-slate-800 uppercase font-medium mt-0.5">Yesterday, 4:15 PM</p>
                        </li>
                        <li class="p-4 hover:bg-slate-50 transition-colors text-center">
                            <button class="text-[10px] font-semibold uppercase tracking-widest text-primary hover:underline py-2">View Audit Trail</button>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
        });
    </script>
}
