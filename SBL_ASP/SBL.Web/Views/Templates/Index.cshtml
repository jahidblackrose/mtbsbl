@{
    ViewData["Title"] = "UI Templates";
}

<div class="space-y-10 animate-fade-in pb-20">
    <!-- Header Section -->
    <div class="border-b border-slate-200 pb-6">
        <h1 class="text-2xl font-extrabold text-slate-900 tracking-tight">Full Component Library</h1>
        <p class="text-slate-500 text-sm mt-1">A comprehensive collection of enterprise-grade UI elements for the MTB Banking Ecosystem.</p>
    </div>

    <!-- 1. BUTTONS & ACTIONS -->
    <section class="space-y-4">
        <h2 class="text-xs font-black uppercase tracking-[0.2em] text-primary flex items-center gap-2">
            <i data-lucide="mouse-pointer-2" class="w-4 h-4"></i> Buttons & Actions
        </h2>
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm space-y-6">
            <div class="flex flex-wrap gap-4 items-center">
                <button class="bg-primary text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-primary/90 transition-all active:scale-95 shadow-lg shadow-primary/20">Primary Solid</button>
                <button class="bg-slate-900 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-slate-800 transition-all active:scale-95 shadow-lg shadow-slate-900/20">Dark Solid</button>
                <button class="bg-white border border-slate-200 text-slate-700 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-slate-50 transition-all active:scale-95 shadow-sm">Outline</button>
                <button class="bg-slate-100 text-slate-600 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-slate-200 transition-all active:scale-95">Secondary</button>
                <button class="text-primary px-4 py-2 rounded-lg text-sm font-bold hover:bg-primary/5 transition-all">Ghost Button</button>
            </div>
            
            <div class="flex flex-wrap gap-4 items-center border-t pt-6">
                <button class="bg-primary text-white px-3 py-1.5 rounded-md text-xs font-bold uppercase tracking-wider flex items-center gap-2">
                    <i data-lucide="plus" class="w-3.5 h-3.5"></i> Add New
                </button>
                <button class="bg-success text-white px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2">
                    <i data-lucide="check-check" class="w-4 h-4"></i> Approve Transaction
                </button>
                <button class="bg-destructive text-white px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2">
                    <i data-lucide="trash-2" class="w-4 h-4"></i> Delete Record
                </button>
                <button disabled class="bg-slate-100 text-slate-400 px-4 py-2 rounded-lg text-sm font-bold cursor-not-allowed border border-slate-200">Disabled State</button>
            </div>

            <div class="flex flex-wrap gap-4 items-center border-t pt-6">
                <div class="flex rounded-lg overflow-hidden border border-slate-200">
                    <button class="px-4 py-2 bg-white text-sm font-bold border-r hover:bg-slate-50 transition-all">Daily</button>
                    <button class="px-4 py-2 bg-primary text-white text-sm font-bold border-r transition-all">Weekly</button>
                    <button class="px-4 py-2 bg-white text-sm font-bold hover:bg-slate-50 transition-all">Monthly</button>
                </div>
                
                <button class="h-10 w-10 flex items-center justify-center rounded-full bg-primary text-white shadow-lg hover:rotate-90 transition-transform duration-500">
                    <i data-lucide="settings" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
    </section>

    <!-- 2. BADGES & STATUSES -->
    <section class="space-y-4">
        <h2 class="text-xs font-black uppercase tracking-[0.2em] text-primary flex items-center gap-2">
            <i data-lucide="tag" class="w-4 h-4"></i> Badges & Indicators
        </h2>
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <div class="flex flex-wrap gap-3">
                <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase bg-primary text-white tracking-widest shadow-sm shadow-primary/20">Primary</span>
                <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase bg-emerald-500 text-white tracking-widest shadow-sm shadow-emerald-500/20">Success</span>
                <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase bg-amber-500 text-white tracking-widest shadow-sm shadow-amber-500/20">Warning</span>
                <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase bg-red-500 text-white tracking-widest shadow-sm shadow-red-500/20">Destructive</span>
                <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase bg-slate-100 text-slate-600 border border-slate-200 tracking-widest">Outline Light</span>
            </div>
            
            <div class="flex flex-wrap gap-6 mt-8 pt-6 border-t">
                <div class="relative">
                    <i data-lucide="bell" class="w-6 h-6 text-slate-400"></i>
                    <span class="absolute -top-1 -right-1 flex h-4 w-4 items-center justify-center rounded-full bg-red-500 text-[8px] font-black text-white ring-2 ring-white">12</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="relative flex h-3 w-3">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
                    </span>
                    <span class="text-xs font-bold text-slate-600">Live Server Status</span>
                </div>
            </div>
        </div>
    </section>

    <!-- 3. CARDS & LAYOUTS -->
    <section class="space-y-4">
        <h2 class="text-xs font-black uppercase tracking-[0.2em] text-primary flex items-center gap-2">
            <i data-lucide="layout" class="w-4 h-4"></i> Information Cards
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Basic Card -->
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
                <div class="p-5 border-b bg-slate-50/50">
                    <h3 class="text-sm font-bold text-slate-900">Standard Header</h3>
                </div>
                <div class="p-5">
                    <p class="text-xs text-slate-500 leading-relaxed font-medium">Standard body text for information delivery. Clean typography and consistent spacing.</p>
                </div>
                <div class="p-4 border-t bg-slate-50/30 flex justify-end">
                    <button class="text-xs font-bold text-primary hover:underline uppercase">View More</button>
                </div>
            </div>

            <!-- Stats Card -->
            <div class="bg-primary text-white rounded-2xl shadow-xl shadow-primary/20 p-6 flex flex-col justify-between overflow-hidden relative">
                <i data-lucide="trending-up" class="absolute -right-4 -bottom-4 w-24 h-24 opacity-10"></i>
                <div>
                    <p class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-70">Monthly Revenue</p>
                    <h4 class="text-3xl font-black mt-1 tracking-tighter">৳4.8M</h4>
                </div>
                <div class="mt-6 flex items-center gap-2">
                    <span class="bg-white/20 text-[10px] px-2 py-0.5 rounded-full font-bold">+12.5%</span>
                    <span class="text-[10px] opacity-60 font-bold uppercase tracking-widest">vs last month</span>
                </div>
            </div>

            <!-- Action Card -->
            <div class="bg-white rounded-2xl border-2 border-dashed border-slate-200 p-6 flex flex-col items-center justify-center text-center hover:border-primary/50 transition-all cursor-pointer group">
                <div class="h-12 w-12 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 group-hover:bg-primary/10 group-hover:text-primary transition-all">
                    <i data-lucide="plus" class="w-6 h-6"></i>
                </div>
                <h4 class="text-sm font-bold mt-4 text-slate-900">Create New Module</h4>
                <p class="text-[10px] text-slate-400 mt-1 uppercase font-bold tracking-widest">Setup new workflow</p>
            </div>
        </div>
    </section>

    <!-- 4. ALERTS & NOTIFICATIONS -->
    <section class="space-y-4">
        <h2 class="text-xs font-black uppercase tracking-[0.2em] text-primary flex items-center gap-2">
            <i data-lucide="alert-octagon" class="w-4 h-4"></i> System Messaging
        </h2>
        <div class="grid gap-4">
            <div class="p-4 rounded-xl border border-emerald-200 bg-emerald-50/50 flex gap-3">
                <i data-lucide="check-circle" class="w-5 h-5 text-emerald-600 shrink-0"></i>
                <div>
                    <h4 class="text-sm font-bold text-emerald-900 tracking-tight">Data Integrity Verified</h4>
                    <p class="text-xs text-emerald-700 font-medium mt-0.5">The application has been successfully scanned and validated for submission.</p>
                </div>
            </div>
            
            <div class="p-4 rounded-xl border border-blue-200 bg-blue-50/50 flex gap-3">
                <i data-lucide="info" class="w-5 h-5 text-blue-600 shrink-0"></i>
                <div>
                    <h4 class="text-sm font-bold text-blue-900 tracking-tight">System Maintenance</h4>
                    <p class="text-xs text-blue-700 font-medium mt-0.5">Scheduled maintenance tonight at 11:59 PM. Some services may be unavailable.</p>
                </div>
            </div>

            <div class="p-4 rounded-xl border border-red-200 bg-red-50/50 flex gap-3">
                <i data-lucide="x-circle" class="w-5 h-5 text-red-600 shrink-0"></i>
                <div>
                    <h4 class="text-sm font-bold text-red-900 tracking-tight">Payment Failed</h4>
                    <p class="text-xs text-red-700 font-medium mt-0.5">The external banking gateway returned an authorization error. Please check user credentials.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- 5. PROGRESS & LOADERS -->
    <section class="space-y-4">
        <h2 class="text-xs font-black uppercase tracking-[0.2em] text-primary flex items-center gap-2">
            <i data-lucide="loader" class="w-4 h-4"></i> Progress Indicators
        </h2>
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm space-y-8">
            <div class="space-y-2">
                <div class="flex justify-between items-center text-xs font-bold uppercase tracking-widest text-slate-500">
                    <span>Processing Application</span>
                    <span class="text-primary font-mono">75%</span>
                </div>
                <div class="w-full bg-slate-100 rounded-full h-2.5 overflow-hidden">
                    <div class="bg-primary h-full rounded-full w-3/4 shadow-[0_0_10px_rgba(37,99,235,0.3)]"></div>
                </div>
            </div>

            <div class="flex flex-wrap gap-10 items-center justify-center py-4">
                <div class="flex flex-col items-center gap-2">
                    <i data-lucide="loader-2" class="w-8 h-8 text-primary animate-spin"></i>
                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Classic</span>
                </div>
                <div class="flex flex-col items-center gap-2">
                    <div class="flex gap-1.5">
                        <div class="w-2 h-2 bg-primary rounded-full animate-bounce"></div>
                        <div class="w-2 h-2 bg-primary rounded-full animate-bounce [animation-delay:0.2s]"></div>
                        <div class="w-2 h-2 bg-primary rounded-full animate-bounce [animation-delay:0.4s]"></div>
                    </div>
                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Dots</span>
                </div>
            </div>
        </div>
    </section>

    <!-- 6. NAVIGATION COMPONENTS -->
    <section class="space-y-4">
        <h2 class="text-xs font-black uppercase tracking-[0.2em] text-primary flex items-center gap-2">
            <i data-lucide="navigation" class="w-4 h-4"></i> Navigation Elements
        </h2>
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm space-y-10">
            <!-- Tabs -->
            <div class="border-b flex gap-8 overflow-x-auto custom-scrollbar">
                <button class="border-b-2 border-primary pb-3 text-sm font-bold text-slate-900 whitespace-nowrap">Active Module</button>
                <button class="border-b-2 border-transparent pb-3 text-sm font-bold text-slate-400 hover:text-slate-600 whitespace-nowrap">Configuration</button>
                <button class="border-b-2 border-transparent pb-3 text-sm font-bold text-slate-400 hover:text-slate-600 whitespace-nowrap">Audit Logs</button>
                <button class="border-b-2 border-transparent pb-3 text-sm font-bold text-slate-400 hover:text-slate-600 whitespace-nowrap">User Access</button>
            </div>

            <!-- Breadcrumbs -->
            <nav class="flex text-xs font-bold uppercase tracking-widest items-center gap-2 text-slate-400">
                <a href="#" class="hover:text-primary transition-colors">Portal</a>
                <i data-lucide="chevron-right" class="w-3 h-3"></i>
                <a href="#" class="hover:text-primary transition-colors">Admin</a>
                <i data-lucide="chevron-right" class="w-3 h-3"></i>
                <span class="text-slate-900">User Management</span>
            </nav>

            <!-- Pagination -->
            <div class="flex items-center justify-center gap-2 pt-4 border-t border-slate-50">
                <button class="w-8 h-8 rounded-lg bg-slate-100 text-slate-400 flex items-center justify-center hover:bg-slate-200 transition-all"><i data-lucide="chevron-left" class="w-4 h-4"></i></button>
                <button class="w-8 h-8 rounded-lg bg-primary text-white flex items-center justify-center font-bold text-xs shadow-lg shadow-primary/20">1</button>
                <button class="w-8 h-8 rounded-lg bg-white border text-slate-600 flex items-center justify-center font-bold text-xs hover:bg-slate-50">2</button>
                <button class="w-8 h-8 rounded-lg bg-white border text-slate-600 flex items-center justify-center font-bold text-xs hover:bg-slate-50">3</button>
                <button class="w-8 h-8 rounded-lg bg-slate-100 text-slate-600 flex items-center justify-center hover:bg-slate-200 transition-all"><i data-lucide="chevron-right" class="w-4 h-4"></i></button>
            </div>
        </div>
    </section>

    <!-- 7. SKELETON LOADERS (UX Standard) -->
    <section class="space-y-4">
        <h2 class="text-xs font-black uppercase tracking-[0.2em] text-primary flex items-center gap-2">
            <i data-lucide="zap" class="w-4 h-4"></i> Skeleton Loading UX
        </h2>
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <div class="flex items-center gap-4 animate-pulse">
                <div class="h-12 w-12 rounded-full bg-slate-200"></div>
                <div class="flex-1 space-y-2">
                    <div class="h-3 bg-slate-200 rounded w-1/4"></div>
                    <div class="h-3 bg-slate-100 rounded w-1/2"></div>
                </div>
            </div>
            <div class="mt-6 space-y-3 animate-pulse">
                <div class="h-20 bg-slate-50 rounded-xl border border-slate-100"></div>
                <div class="h-3 bg-slate-100 rounded w-full"></div>
                <div class="h-3 bg-slate-50 rounded w-5/6"></div>
            </div>
        </div>
    </section>

    <!-- 8. FORMS & ADVANCED INPUTS -->
    <section class="space-y-4">
        <h2 class="text-xs font-black uppercase tracking-[0.2em] text-primary flex items-center gap-2">
            <i data-lucide="check-square" class="w-4 h-4"></i> Forms & Input States
        </h2>
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Valid state -->
            <div class="space-y-2">
                <label class="text-[10px] font-bold uppercase tracking-widest text-slate-800 ml-1">Verified Input</label>
                <div class="relative">
                    <input type="text" value="Md. Jahidur Rahman" class="flex h-11 w-full rounded-xl border border-emerald-500 bg-white px-4 py-2 text-sm outline-none font-bold text-emerald-700" />
                    <i data-lucide="check-circle-2" class="absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-emerald-500"></i>
                </div>
                <p class="text-[10px] text-emerald-600 font-bold ml-1 italic">Name verified against NID Database.</p>
            </div>

            <!-- Error state -->
            <div class="space-y-2">
                <label class="text-[10px] font-bold uppercase tracking-widest text-slate-800 ml-1">Failed Validation</label>
                <div class="relative">
                    <input type="text" value="invalid-amount-format" class="flex h-11 w-full rounded-xl border border-red-500 bg-red-50 px-4 py-2 text-sm outline-none font-bold text-red-700" />
                    <i data-lucide="alert-circle" class="absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-red-500"></i>
                </div>
                <p class="text-[10px] text-red-600 font-bold ml-1 italic">Enter numeric value only (৳).</p>
            </div>

            <!-- Multi-Select Placeholder -->
            <div class="md:col-span-2 space-y-2">
                <label class="text-[10px] font-bold uppercase tracking-widest text-slate-800 ml-1">Searchable Select (Standard UI)</label>
                <select id="template-select" class="w-full">
                    <option value="">Choose Multiple Roles...</option>
                    <option value="RM">Relationship Manager</option>
                    <option value="CIB">CIB Officer</option>
                    <option value="UW">Underwriter</option>
                    <option value="CAD">CAD Operations</option>
                </select>
            </div>
        </div>
    </section>
</div>

<!-- Modal Example -->
<div id="demo-modal" class="hidden fixed inset-0 z-[10001] flex items-center justify-center p-4 bg-slate-900/80 backdrop-blur-sm animate-fade-in">
    <div class="bg-white rounded-3xl shadow-2xl max-w-lg w-full overflow-hidden border">
        <div class="p-8">
            <div class="flex items-center justify-between border-b pb-4 mb-6">
                <h3 class="text-xl font-black text-slate-900 tracking-tight">System Information</h3>
                <button onclick="document.getElementById('demo-modal').classList.add('hidden')" class="text-slate-400 hover:text-slate-900 transition-colors"><i data-lucide="x" class="w-5 h-5"></i></button>
            </div>
            <p class="text-sm text-slate-500 leading-relaxed font-medium mb-8">This is a standard large modal template for complex information displays or multi-step processing flows.</p>
            <div class="flex justify-end gap-3">
                <button onclick="document.getElementById('demo-modal').classList.add('hidden')" class="px-6 py-2.5 text-xs font-bold text-slate-500 hover:bg-slate-50 rounded-xl transition-all">Close</button>
                <button class="bg-primary text-white px-8 py-2.5 rounded-xl text-xs font-bold shadow-lg shadow-primary/20">Understood</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();

            // Initialize searchable select for template
            new TomSelect("#template-select", {
                create: false,
                sortField: { field: "text", direction: "asc" },
                maxItems: 3
            });
        });

        function showLoaderDemo() {
            MTBLoader.show();
            setTimeout(() => MTBLoader.hide(), 2000);
        }
    </script>
}
