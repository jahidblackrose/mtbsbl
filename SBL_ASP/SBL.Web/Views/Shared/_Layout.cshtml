<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MTB Loan Portal</title>
    <!-- Fonts (System Stack for Security/Offline) -->
    <style>
        body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji"; }
    </style>
    <!-- Tailwind Output -->
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <!-- Modern UI Component Libraries -->
    <link rel="stylesheet" href="~/lib/flatpickr/flatpickr.min.css">
    <link rel="stylesheet" href="~/lib/tom-select/tom-select.css">
    <link rel="stylesheet" href="~/lib/toastify/toastify.min.css">
    
    <!-- Icons -->
    <script src="~/lib/jquery/jquery-3.7.1.min.js"></script>
    <script src="~/lib/lucide/lucide.min.js"></script>
    <style>
        /* Sidebar transition */
        #sidebar { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        
        /* Custom scrollbar */
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        
        /* Flatpickr Year Selection Improvement */
        .flatpickr-calendar .numInputWrapper span { display: block !important; opacity: 1 !important; }
        .flatpickr-current-month .numInputWrapper input.cur-year { font-weight: 400 !important; cursor: pointer; }
        .flatpickr-monthDropdown-months, .flatpickr-monthDropdown-month { font-weight: 400 !important; }
    </style>
</head>
<body class="min-h-screen bg-slate-50 text-slate-900 antialiased selection:bg-blue-100 selection:text-blue-900 font-normal">
    <!-- Full Page Loader -->
    <div id="globalLoader" class="fixed inset-0 z-[10000] flex items-center justify-center bg-white/80 backdrop-blur-sm transition-opacity duration-300 pointer-events-none opacity-0">
        <div class="flex flex-col items-center gap-3">
            <i data-lucide="loader-2" class="h-10 w-10 animate-spin text-primary"></i>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500 animate-pulse">Synchronizing Data</p>
        </div>
    </div>

    <!-- Mobile Sidebar Backdrop -->
    <div id="sidebarBackdrop" class="fixed inset-0 bg-slate-900/60 z-40 hidden opacity-0 transition-opacity duration-300"></div>

    <!-- Top Progress Bar -->
    <div id="topProgressBar" class="fixed top-0 left-0 h-0.5 bg-primary z-[9999] transition-all duration-500 ease-out w-0 opacity-0"></div>

    <div class="relative flex min-h-screen flex-col">
        <!-- Navbar -->
        <header class="sticky top-0 z-30 flex h-14 items-center gap-4 border-b bg-white px-4 shadow-sm">
            <button id="toggleSidebar" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors hover:bg-slate-100 h-9 w-9 shrink-0">
                <i data-lucide="menu" class="h-5 w-5"></i>
            </button>

            <div class="flex items-center gap-2">
                <img src="~/images/logo.jpeg" alt="MTB Logo" class="h-8 w-auto rounded-lg shadow-sm" />
                <span class="hidden text-[10px] font-semibold text-slate-800 sm:inline uppercase tracking-[0.2em] border-l pl-3 ml-1">
                    SBL/SBL PLUS Application Portal
                </span>
            </div>

            <div class="ml-auto flex items-center gap-3">
                <!-- User Profile -->
                <a asp-controller="Account" asp-action="Profile" class="flex items-center gap-2.5 px-2.5 hover:bg-slate-50 rounded-xl py-1.5 transition-all group border border-transparent">
                    <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-primary text-[10px] font-bold text-white shadow-md group-hover:scale-110 transition-transform">
                        @Context.Session.GetString("UserName")?[0]
                    </div>
                    <div class="hidden text-left md:block">
                        <p class="text-[11px] font-semibold leading-none text-slate-900">@Context.Session.GetString("UserName")</p>
                        <p class="text-[9px] text-slate-800 mt-0.5 uppercase font-medium tracking-tighter">@Context.Session.GetString("UserRole")</p>
                    </div>
                </a>
                
                <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" class="ms-1">
                    <button type="submit" class="p-2 text-red-500 hover:text-red-600 transition-all" title="Logout">
                        <i data-lucide="log-out" class="h-4 w-4"></i>
                    </button>
                </form>
            </div>
        </header>

        <div class="flex flex-1">
            <!-- Sidebar -->
            <aside id="sidebar" class="fixed left-0 top-14 z-50 flex h-[calc(100vh-3.5rem)] w-56 flex-col border-r bg-sidebar -translate-x-full md:translate-x-0 transition-transform md:transition-none shadow-xl md:shadow-none">
                <nav class="flex-1 space-y-1 p-4">
                    <a asp-controller="Dashboard" asp-action="Index" 
                       class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-semibold transition-all @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "bg-sidebar-accent text-sidebar-primary shadow-md" : "text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground")">
                        <i data-lucide="layout-dashboard" class="h-4 w-4 shrink-0"></i>
                        <span>Dashboard</span>
                    </a>
                    <a asp-controller="Demo" asp-action="Index" 
                       class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-semibold transition-all @(ViewContext.RouteData.Values["controller"]?.ToString() == "Demo" ? "bg-sidebar-accent text-sidebar-primary shadow-md" : "text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground")">
                        <i data-lucide="component" class="h-4 w-4 shrink-0"></i>
                        <span>Component Demo</span>
                    </a>
                    <a asp-controller="Templates" asp-action="Index" 
                       class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-semibold transition-all @(ViewContext.RouteData.Values["controller"]?.ToString() == "Templates" ? "bg-sidebar-accent text-sidebar-primary shadow-md" : "text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground")">
                        <i data-lucide="layout-template" class="h-4 w-4 shrink-0"></i>
                        <span>UI Templates</span>
                    </a>
                    <a asp-controller="Account" asp-action="Profile" 
                       class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-semibold transition-all @(ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "bg-sidebar-accent text-sidebar-primary shadow-md" : "text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground")">
                        <i data-lucide="user-circle" class="h-4 w-4 shrink-0"></i>
                        <span>My Profile</span>
                    </a>
                    <div class="pt-4 mt-4 border-t border-sidebar-border">
                        <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-sidebar-muted px-3 mb-2">Internal Tools</p>
                        <a href="#" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-semibold text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground transition-all">
                            <i data-lucide="file-text" class="h-4 w-4 shrink-0"></i>
                            <span>Applications</span>
                        </a>
                    </div>
                </nav>

                <div class="border-t border-sidebar-border p-4 bg-sidebar-accent/20">
                    <div class="flex items-center gap-2 text-[10px] uppercase font-semibold text-sidebar-muted tracking-widest overflow-hidden">
                        <i data-lucide="building-2" class="h-3 w-3 shrink-0"></i>
                        <span class="truncate">@Context.Session.GetString("BranchName")</span>
                    </div>
                </div>
            </aside>

            <!-- Main Content -->
            <main id="mainContent" class="flex-1 transition-all duration-300 md:ml-56 p-4 md:p-6 lg:p-10">
                <div class="animate-fade-in max-w-[1400px] mx-auto">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <!-- Modern UI Component Libraries -->
    <script src="~/lib/flatpickr/flatpickr.min.js"></script>
    <script src="~/lib/tom-select/tom-select.complete.min.js"></script>
    <script src="~/lib/toastify/toastify.js"></script>

    <script>
        lucide.createIcons();

        // Standard Flatpickr Config for year/month dropdowns
        window.MTBFlatpickrConfig = {
            dateFormat: "Y-m-d",
            monthSelectorType: "dropdown",
            static: true,
            disableMobile: true,
            animate: true
        };

        // 1. Loader Control
        window.MTBLoader = {
            show: () => {
                const loader = document.getElementById('globalLoader');
                loader.classList.remove('opacity-0', 'pointer-events-none');
                loader.classList.add('opacity-100');
            },
            hide: () => {
                const loader = document.getElementById('globalLoader');
                loader.classList.remove('opacity-100');
                loader.classList.add('opacity-0', 'pointer-events-none');
            }
        };

        // 2. Toast Notifications (BOTTOM-RIGHT)
        window.MTBToast = {
            show: (message, type = 'success') => {
                let bgColor = "#10b981"; 
                if (type === 'error') bgColor = "#ef4444";
                if (type === 'warning') bgColor = "#f59e0b";
                if (type === 'info') bgColor = "#3b82f6";

                Toastify({
                    text: message,
                    duration: 4000,
                    gravity: "bottom",
                    position: "right",
                    stopOnFocus: true,
                    style: { background: bgColor, borderRadius: "12px", fontWeight: "600", fontSize: "12px" }
                }).showToast();
            },
            success: (msg) => window.MTBToast.show(msg, 'success'),
            error: (msg) => window.MTBToast.show(msg, 'error')
        };

        @if (TempData["SuccessMessage"] != null) {
            <text>MTBToast.success("@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(TempData["SuccessMessage"]?.ToString()))");</text>
        }
        @if (TempData["ErrorMessage"] != null) {
            <text>MTBToast.error("@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(TempData["ErrorMessage"]?.ToString()))");</text>
        }

        // 3. Robust Sidebar & Mobile Logic
        const toggleBtn = document.getElementById('toggleSidebar');
        const sidebar = document.getElementById('sidebar');
        const backdrop = document.getElementById('sidebarBackdrop');
        const main = document.getElementById('mainContent');

        function toggleSidebar() {
            if (window.innerWidth < 768) {
                // Mobile
                const isOpen = !sidebar.classList.contains('-translate-x-full');
                if (isOpen) {
                    sidebar.classList.add('-translate-x-full');
                    backdrop.classList.add('hidden');
                    backdrop.classList.remove('opacity-100');
                } else {
                    sidebar.classList.remove('-translate-x-full');
                    backdrop.classList.remove('hidden');
                    setTimeout(() => backdrop.classList.add('opacity-100'), 10);
                }
            } else {
                // Desktop
                if (sidebar.classList.contains('w-56')) {
                    sidebar.classList.replace('w-56', 'w-0');
                    sidebar.classList.add('overflow-hidden', 'border-r-0');
                    main.classList.replace('md:ml-56', 'md:ml-0');
                } else {
                    sidebar.classList.replace('w-0', 'w-56');
                    sidebar.classList.remove('overflow-hidden', 'border-r-0');
                    main.classList.replace('md:ml-0', 'md:ml-56');
                }
            }
        }

        toggleBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            toggleSidebar();
        });

        backdrop.addEventListener('click', toggleSidebar);

        // Auto-hide on mobile click outside
        document.addEventListener('click', (e) => {
            if (window.innerWidth < 768 && !sidebar.contains(e.target) && !toggleBtn.contains(e.target)) {
                if (!sidebar.classList.contains('-translate-x-full')) toggleSidebar();
            }
        });

        // Top Progress Bar
        const progressBar = document.getElementById('topProgressBar');
        window.addEventListener('beforeunload', () => {
            progressBar.style.opacity = '1';
            progressBar.style.width = '100%';
        });

        document.querySelectorAll('a').forEach(link => {
            if (link.hostname === window.location.hostname && !link.hash && link.target !== '_blank' && !link.getAttribute('href').startsWith('javascript:')) {
                link.addEventListener('click', () => {
                    progressBar.style.opacity = '1';
                    progressBar.style.width = '40%';
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
