                        <i data-lucide="file-text" class="w-8 h-8 opacity-40"></i>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold uppercase tracking-[0.2em]">Secure Document Viewer</p>
                        <p class="text-[9px] font-bold mt-1 text-slate-400 uppercase tracking-widest">Click preview to generate document</p>
