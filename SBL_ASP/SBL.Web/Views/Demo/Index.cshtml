@section Scripts {
    <script>
        // --- SmartTable Module (State-Driven) ---
        const SmartTable = (() => {
            let fullData = @Html.Raw(Json.Serialize(ViewBag.TableData));
            let filteredData = [...fullData];
            
            let state = {
                currentPage: 1,
                pageSize: 10,
                sortKey: 'Id',
                sortOrder: 'asc',
                searchQuery: ''
            };

            const selectors = {
                body: document.getElementById('tableBody'),
                info: document.getElementById('tableInfo'),
                pager: document.getElementById('paginationControls'),
                search: document.getElementById('tableSearch'),
                size: document.getElementById('pageSize')
            };

            const render = () => {
                // 1. Filter
                filteredData = fullData.filter(item => 
                    item.name.toLowerCase().includes(state.searchQuery.toLowerCase()) ||
                    item.email.toLowerCase().includes(state.searchQuery.toLowerCase()) ||
                    item.status.toLowerCase().includes(state.searchQuery.toLowerCase())
                );

                // 2. Sort
                filteredData.sort((a, b) => {
                    let valA = a[state.sortKey.toLowerCase()];
                    let valB = b[state.sortKey.toLowerCase()];
                    
                    if (typeof valA === 'string') {
                        return state.sortOrder === 'asc' ? valA.localeCompare(valB) : valB.localeCompare(valA);
                    }
                    return state.sortOrder === 'asc' ? valA - valB : valB - valA;
                });

                // 3. Paginate
                const total = filteredData.length;
                const totalPages = Math.ceil(total / state.pageSize);
                state.currentPage = Math.min(state.currentPage, totalPages || 1);
                
                const start = (state.currentPage - 1) * state.pageSize;
                const end = start + parseInt(state.pageSize);
                const pageData = filteredData.slice(start, end);

                // 4. Build Table Rows
                selectors.body.innerHTML = pageData.map(item => `
                    <tr class="hover:bg-slate-50/80 transition-colors">
                        <td class="p-4">#${item.id}</td>
                        <td class="p-4 font-bold text-slate-900">${item.name}</td>
                        <td class="p-4 font-normal text-slate-500">${item.email}</td>
                        <td class="p-4">
                            <span class="px-2 py-1 rounded-lg text-[9px] font-black uppercase tracking-widest ${getStatusClass(item.status)}">
                                ${item.status}
                            </span>
                        </td>
                        <td class="p-4 text-right">
                            <button class="p-1.5 hover:bg-white rounded-lg border border-transparent hover:border-slate-200 transition-all text-primary">
                                <i data-lucide="external-link" class="h-3.5 w-3.5"></i>
                            </button>
                        </td>
                    </tr>
                `).join('') || '<tr><td colspan="5" class="p-10 text-center text-slate-400">No matching records found</td></tr>';

                // 5. Build Pagination UI
                selectors.info.innerText = `Showing ${total ? start + 1 : 0} to ${Math.min(end, total)} of ${total} entries`;
                
                let pagerHtml = `
                    <button onclick="SmartTable.setPage(${state.currentPage - 1})" ${state.currentPage === 1 ? 'disabled' : ''} class="h-8 w-8 flex items-center justify-center rounded-lg border bg-white disabled:opacity-30 disabled:cursor-not-allowed hover:bg-slate-50">
                        <i data-lucide="chevron-left" class="h-3.5 w-3.5"></i>
                    </button>
                `;

                for (let i = 1; i <= totalPages; i++) {
                    if (totalPages > 5 && i > 2 && i < totalPages - 1 && Math.abs(i - state.currentPage) > 1) {
                        if (i === 3 || i === totalPages - 1) pagerHtml += '<span class="px-1 text-slate-300">...</span>';
                        continue;
                    }
                    pagerHtml += `
                        <button onclick="SmartTable.setPage(${i})" class="h-8 w-8 text-[10px] font-bold rounded-lg border ${state.currentPage === i ? 'bg-primary text-white border-primary shadow-md shadow-primary/20' : 'bg-white hover:bg-slate-50'}">
                            ${i}
                        </button>
                    `;
                }

                pagerHtml += `
                    <button onclick="SmartTable.setPage(${state.currentPage + 1})" ${state.currentPage === totalPages || totalPages === 0 ? 'disabled' : ''} class="h-8 w-8 flex items-center justify-center rounded-lg border bg-white disabled:opacity-30 disabled:cursor-not-allowed hover:bg-slate-50">
                        <i data-lucide="chevron-right" class="h-3.5 w-3.5"></i>
                    </button>
                `;
                
                selectors.pager.innerHTML = pagerHtml;
                lucide.createIcons();
            };

            const getStatusClass = (status) => {
                if (status === 'Active') return 'bg-emerald-50 text-emerald-600';
                if (status === 'Pending') return 'bg-amber-50 text-amber-600';
                if (status === 'On Hold') return 'bg-slate-100 text-slate-600';
                return 'bg-slate-50 text-slate-400';
            };

            return {
                init: () => {
                    selectors.search.oninput = (e) => { state.searchQuery = e.target.value; state.currentPage = 1; render(); };
                    selectors.size.onchange = (e) => { state.pageSize = e.target.value; state.currentPage = 1; render(); };
                    render();
                },
                setPage: (p) => { state.currentPage = p; render(); },
                sortBy: (key) => {
                    if (state.sortKey === key) state.sortOrder = state.sortOrder === 'asc' ? 'desc' : 'asc';
                    else { state.sortKey = key; state.sortOrder = 'asc'; }
                    render();
                },
                export: (type) => {
                    const data = filteredData;
                    if (type === 'json') {
                        const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
                        const url = URL.createObjectURL(blob);
                        const a = document.createElement('a');
                        a.href = url; a.download = 'mtb_data_export.json'; a.click();
                    } else {
                        const headers = Object.keys(data[0]).join(',');
                        const csv = data.map(row => Object.values(row).join(',')).join('\n');
                        const blob = new Blob([[headers, csv].join('\n')], { type: 'text/csv' });
                        const url = URL.createObjectURL(blob);
                        const a = document.createElement('a');
                        a.href = url; a.download = 'mtb_data_export.csv'; a.click();
                    }
                    MTBToast.success(`Exported ${data.length} records to ${type.toUpperCase()}`);
                }
            };
        })();

        // Global Bindings for the table
        window.sortBy = SmartTable.sortBy;
        window.exportData = SmartTable.export;

        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
            SmartTable.init();

            // 1. Tom Select
            new TomSelect("#ts-select", {
                create: false,
                sortField: { field: "text", direction: "asc" }
            });

            // 2. User-Friendly Date Picker
            flatpickr("#fp-date", window.MTBFlatpickrConfig);
        });

        const form = document.getElementById('demoForm');
        const sBtn = document.getElementById('sub-btn');
        const sText = document.getElementById('sub-text');
        const sSpin = document.getElementById('sub-spin');
        const mod = document.getElementById('cnf-modal');

        function clsMod() { mod.classList.add('hidden'); }
        sBtn.addEventListener('click', () => {
            if(form.checkValidity()) mod.classList.remove('hidden');
            else {
                MTBToast.error("Please correct the form errors.");
                form.reportValidity();
            }
        });

        function fnlSub() {
            clsMod();
            sBtn.disabled = true;
            sBtn.classList.add('opacity-70');
            sText.innerText = "Authenticating Transaction...";
            sSpin.classList.remove('hidden');
            lucide.createIcons();
            MTBLoader.show();
            setTimeout(() => form.submit(), 1000);
        }

        document.getElementById('dtSearch').addEventListener('input', (e) => {
            const f = e.target.value.toLowerCase();
            document.querySelectorAll('#demoDataTable tbody tr').forEach(r => r.style.display = r.innerText.toLowerCase().includes(f) ? '' : 'none');
        });

        // PDF Generation Logic
        function getPdfUrl() {
            const name = encodeURIComponent(document.getElementById('pdfCustName').value);
            const amount = encodeURIComponent(document.getElementById('pdfAmount').value);
            const baseUrl = '@Url.Action("GeneratePdf", "Demo")';
            return `${baseUrl}?customerName=${name}&amount=${amount}&branch=Main&purpose=Business Expansion`;
        }

        function previewPdf() {
            const url = getPdfUrl();
            const viewer = document.getElementById('pdfViewer');
            const placeholder = document.getElementById('viewerPlaceholder');
            
            viewer.src = url;
            viewer.classList.remove('hidden');
            placeholder.classList.add('hidden');
            
            MTBToast.success("Generating preview...");
        }

        function downloadPdf() {
            const url = getPdfUrl();
            const link = document.createElement('a');
            link.href = url;
            link.download = 'MTB_Application_Letter.pdf';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            
            MTBToast.success("Download started.");
        }

        function downloadMultiPagePdf() {
            const name = encodeURIComponent(document.getElementById('pdfCustName').value);
            const baseUrl = '@Url.Action("GenerateMultiPagePdf", "Demo")';
            const url = `${baseUrl}?customerName=${name}`;
            
            const link = document.createElement('a');
            link.href = url;
            link.download = 'MTB_Full_Application.pdf';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            
            MTBToast.success("Generating multi-page document...");
        }
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
