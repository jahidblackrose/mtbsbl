                    </div>

                    <div class="flex flex-wrap gap-3 pt-4">
                        <button type="button" onclick="previewPdf()" class="bg-primary text-white px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex items-center gap-2">
                            <i data-lucide="eye" class="w-4 h-4"></i> Preview PDF
                        </button>
                        <button type="button" onclick="downloadPdf()" class="bg-slate-100 text-slate-600 px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-slate-200 transition-all flex items-center gap-2 border border-slate-200">
                            <i data-lucide="download" class="w-4 h-4"></i> Download File
                        </button>
                        <button type="button" onclick="downloadMultiPagePdf()" class="bg-primary text-white px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex items-center gap-2">
