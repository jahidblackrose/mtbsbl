</section>

<!-- 10. ADVANCED DATATABLE DEMO -->
<section class="space-y-4 pt-6">
    <h2 class="text-xs font-black uppercase tracking-[0.2em] text-primary flex items-center gap-2">
        <i data-lucide="table-2" class="w-4 h-4"></i> Modern Data Management Engine
    </h2>
    
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <!-- Toolbar -->
        <div class="p-4 border-b bg-slate-50/50 flex flex-col md:flex-row gap-4 items-center justify-between">
            <div class="flex items-center gap-3 w-full md:w-auto">
                <div class="relative w-full md:w-64">
                    <input type="text" id="tableSearch" placeholder="Search records..." 
                           class="w-full h-9 pl-9 pr-4 text-xs rounded-xl border border-slate-200 bg-white focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all font-medium" />
                    <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400"></i>
                </div>
                <select id="pageSize" class="h-9 px-2 text-[10px] font-bold uppercase rounded-xl border border-slate-200 bg-white outline-none cursor-pointer">
                    <option value="5">5 per page</option>
                    <option value="10" selected>10 per page</option>
                    <option value="25">25 per page</option>
                </select>
            </div>

            <div class="flex items-center gap-2 w-full md:w-auto">
                <button onclick="exportData('csv')" class="flex-1 md:flex-none inline-flex items-center justify-center gap-2 px-4 py-2 bg-white border border-slate-200 text-slate-700 text-[10px] font-bold uppercase tracking-widest rounded-xl hover:bg-slate-50 transition-all">
                    <i data-lucide="file-spreadsheet" class="h-3.5 w-3.5 text-emerald-600"></i> Export CSV
                </button>
                <button onclick="exportData('json')" class="flex-1 md:flex-none inline-flex items-center justify-center gap-2 px-4 py-2 bg-white border border-slate-200 text-slate-700 text-[10px] font-bold uppercase tracking-widest rounded-xl hover:bg-slate-50 transition-all">
                    <i data-lucide="code" class="h-3.5 w-3.5 text-blue-600"></i> Export JSON
                </button>
            </div>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse" id="smartTable">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="p-4 text-[10px] font-black uppercase tracking-widest text-slate-400 cursor-pointer hover:text-primary transition-colors group" onclick="sortBy('Id')">
                            <div class="flex items-center gap-1">
                                ID <i data-lucide="chevrons-up-down" class="h-3 w-3 opacity-50 group-hover:opacity-100"></i>
                            </div>
                        </th>
                        <th class="p-4 text-[10px] font-black uppercase tracking-widest text-slate-400 cursor-pointer hover:text-primary transition-colors group" onclick="sortBy('Name')">
                            <div class="flex items-center gap-1">
                                Name <i data-lucide="chevrons-up-down" class="h-3 w-3 opacity-50 group-hover:opacity-100"></i>
                            </div>
                        </th>
                        <th class="p-4 text-[10px] font-black uppercase tracking-widest text-slate-400 cursor-pointer hover:text-primary transition-colors group" onclick="sortBy('Email')">
                            <div class="flex items-center gap-1">
                                Email <i data-lucide="chevrons-up-down" class="h-3 w-3 opacity-50 group-hover:opacity-100"></i>
                            </div>
                        </th>
                        <th class="p-4 text-[10px] font-black uppercase tracking-widest text-slate-400 cursor-pointer hover:text-primary transition-colors group" onclick="sortBy('Status')">
                            <div class="flex items-center gap-1">
                                Status <i data-lucide="chevrons-up-down" class="h-3 w-3 opacity-50 group-hover:opacity-100"></i>
                            </div>
                        </th>
                        <th class="p-4 text-[10px] font-black uppercase tracking-widest text-slate-400 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="tableBody" class="divide-y divide-slate-50 font-medium text-xs text-slate-700">
                    <!-- Dynamic Content -->
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="p-4 border-t bg-slate-50/30 flex items-center justify-between">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest" id="tableInfo">
                Showing 0 to 0 of 0 entries
            </p>
            <div class="flex items-center gap-1" id="paginationControls">
                <!-- Dynamic Buttons -->
            </div>
        </div>
    </div>
</section>
</div>

<!-- Modal -->
